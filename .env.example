# PostgreSQL password (required for Docker Compose)
POSTGRES_PASSWORD=trace_password

# JWT secret (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
TRACE_JWT_SECRET=

# Port to expose the app on (default: 8000)
PORT=8000

# CORS origins (comma-separated, default: *)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database settings
# TRACE_DB_POOL_SIZE=5
# TRACE_DB_MAX_OVERFLOW=10
# TRACE_DB_ECHO=false

# Upload limits
# TRACE_MAX_UPLOAD_SIZE_MB=50

# Rate limiting (requests per minute per IP)
# TRACE_RATE_LIMIT_PER_MINUTE=10

# Allow new user registration (set to false after creating your account)
# TRACE_ALLOW_SIGNUP=true
